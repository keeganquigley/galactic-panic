---
layout: base.njk
title: Galactic Panic
description: ""
---

{% import "saucer.njk" as ui -%}
<section class="hero">
  <div class="hero-eyebrow">/// incoming transmission /// est. 2026</div>
  {{ ui.saucer("saucer-icon", "margin-bottom: 1rem; opacity: 0.6;") }}
  <h1 class="hero-title">{{ artist.name }}</h1>
  <p class="hero-tagline">{% if artist.tagline %}{{ artist.tagline }}{% else %}Do not adjust your receiver.{% endif %}</p>
</section>

{% set songs = collections.songs %}
{% set latest = songs[0] %}

{% if latest %}
<section class="latest-release">
  <div class="latest-release-art">
    {% if latest.cover_src %}
      {% image latest.cover_src, latest.title + " cover", "(max-width: 700px) 100vw, 480px", "", "eager" %}
    {% else %}
      <div class="latest-release-art-placeholder">{{ latest.title }}</div>
    {% endif %}
  </div>
  <div>
    <div class="latest-release-meta">Latest release · {{ latest.latest_release_date | prettyDate }}</div>
    <h2>{{ latest.title }}</h2>
    <div class="song-listen">
      {% if latest.spotify_url %}<a href="{{ latest.spotify_url }}">Spotify</a>{% endif %}
      {% if latest.bandcamp_url %}<a href="{{ latest.bandcamp_url }}">Bandcamp</a>{% endif %}
      {% if latest.apple_music_url %}<a href="{{ latest.apple_music_url }}">Apple Music</a>{% endif %}
      <a href="/songs/{{ latest.slug }}/">More about this song</a>
    </div>
  </div>
</section>
{% else %}
<section class="empty-state">
  No releases yet. Check back soon.
</section>
{% endif %}

<div class="saucer-divider">─── ◇ ─── ◆ ─── ◇ ───</div>

{% if songs.length > 1 %}
<section>
  <h2>More music</h2>
  <div class="songs-grid">
    {% for song in songs.slice(1, 7) %}
      {% renderFile "./site/_includes/song-card.njk", { song: song } %}
    {% endfor %}
  </div>
</section>
{% endif %}

---
layout: base.njk
title: Music
permalink: /music/
albumJsonLd: true
---

<h1>Music</h1>
<p class="eyebrow">All releases, most recent first</p>

{% set songs = collections.songs %}

{% if songs.length > 0 %}
<div class="songs-grid">
  {% for song in songs %}
    {% renderFile "./site/_includes/song-card.njk", { song: song } %}
  {% endfor %}
</div>
{% else %}
<div class="empty-state">
  No releases yet. Add a song folder under <code>content/songs/</code> with a metadata.json.
</div>
{% endif %}

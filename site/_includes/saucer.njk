{# Flying-saucer glyph, used in the header brand, footer, and homepage hero.
   Import and call as a macro so the three-ellipse SVG lives in one place:
     {% import "saucer.njk" as ui %}
     {{ ui.saucer("saucer-icon-sm") }}
     {{ ui.saucer("saucer-icon", "opacity: 0.6;") }}
   `className` sets the class; optional `style` adds an inline style attribute. #}
{% macro saucer(className, style="") -%}
<svg class="{{ className }}" viewBox="0 0 64 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"{% if style %} style="{{ style }}"{% endif %}><ellipse cx="32" cy="18" rx="30" ry="10" fill="currentColor" opacity="0.3"/><ellipse cx="32" cy="16" rx="22" ry="7" fill="currentColor" opacity="0.5"/><ellipse cx="32" cy="13" rx="10" ry="6" fill="currentColor" opacity="0.7"/></svg>
{%- endmacro %}

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% set pageTitle %}{% if title %}{{ title }} — {% endif %}{{ artist.project }}{% endset %}
  {% set metaDesc = description or artist.tagline or "Do not adjust your receiver." %}
  {% set socialImageUrl = (socialImage or "/assets/apple-touch-icon.png") | absoluteUrl %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ metaDesc }}">
  <link rel="canonical" href="{{ page.url | absoluteUrl }}">

  <!-- Open Graph / Facebook -->
  <meta property="og:site_name" content="{{ artist.project }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ metaDesc }}">
  <meta property="og:url" content="{{ page.url | absoluteUrl }}">
  <meta property="og:image" content="{{ socialImageUrl }}">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ metaDesc }}">
  <meta name="twitter:image" content="{{ socialImageUrl }}">

  {# JSON-LD structured data for SEO. Song pages describe a MusicRecording;
     the music page describes the EP as a MusicAlbum. Both are derived from
     metadata.json via filters in .eleventy.js. #}
  {% if song %}
  <script type="application/ld+json">{{ song | musicRecordingLd | safe }}</script>
  {% elif albumJsonLd %}
  <script type="application/ld+json">{{ collections.songs | musicAlbumLd | safe }}</script>
  {% endif %}

  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
  <link rel="stylesheet" href="/assets/style.css">
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="brand">
        <svg class="saucer-icon-sm" viewBox="0 0 64 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><ellipse cx="32" cy="18" rx="30" ry="10" fill="currentColor" opacity="0.3"/><ellipse cx="32" cy="16" rx="22" ry="7" fill="currentColor" opacity="0.5"/><ellipse cx="32" cy="13" rx="10" ry="6" fill="currentColor" opacity="0.7"/></svg>
        <span class="brand-name">{{ artist.name }}</span>
      </a>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="/music/">Music</a>
        <a href="/shows/">Shows</a>
        <a href="/store/">Store</a>
        <a href="/about/">About</a>
        <a href="/press/">Press</a>
      </nav>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-name">
        <svg class="saucer-icon-sm" viewBox="0 0 64 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="vertical-align: middle; margin-right: 0.5em;"><ellipse cx="32" cy="18" rx="30" ry="10" fill="currentColor" opacity="0.3"/><ellipse cx="32" cy="16" rx="22" ry="7" fill="currentColor" opacity="0.5"/><ellipse cx="32" cy="13" rx="10" ry="6" fill="currentColor" opacity="0.7"/></svg>
        {{ artist.project }}
      </div>
      <div class="footer-links">
        {% if artist.links.bandcamp %}<a href="{{ artist.links.bandcamp }}">Bandcamp</a>{% endif %}
        {% if artist.links.spotify %}<a href="{{ artist.links.spotify }}">Spotify</a>{% endif %}
        {% if artist.links.instagram %}<a href="{{ artist.links.instagram }}">Instagram</a>{% endif %}
        {% if artist.links.youtube %}<a href="{{ artist.links.youtube }}">YouTube</a>{% endif %}
        {% if artist.links.linktree %}<a href="{{ artist.links.linktree }}">Linktree</a>{% endif %}
        {% if artist.links.email %}<a href="{{ artist.links.email }}">Email</a>{% endif %}
      </div>
      <div class="footer-meta">© {{ currentYear }} {{ artist.name }}.</div>
      <div class="footer-meta">This music was made by real humans.</div>
      <div class="footer-transmission">/// transmission from <a href="https://www.youtube.com/watch?v=dQw4w9WgXcQ" class="transmission-signal" rel="noopener">sector 7g</a> ///</div>
    </div>
  </footer>

  <!-- GoatCounter privacy-friendly analytics -->
  <script data-goatcounter="https://galacticpanic.goatcounter.com/count"
          async src="//gc.zgo.at/count.js"></script>
</body>
</html>

{# Song card used on the homepage ("More music") and the /music/ grid. Expects a
   `song` variable in scope (both call sites loop with `for song in ...`). Kept
   here so the two grids can't drift — they previously had, the homepage copy
   having silently lost the "Unreleased" fallback. #}
<a href="/songs/{{ song.slug }}/" class="song-card">
  <div class="song-card-art">
    {% if song.cover_src %}{% image song.cover_src, "", "(max-width: 600px) 45vw, 300px" %}{% endif %}
  </div>
  <div class="song-card-body">
    <div class="song-card-title">{{ song.title }}</div>
    <div class="song-card-meta">
      {% if song.latest_release_date %}{{ song.latest_release_date | prettyDate }}{% else %}Unreleased{% endif %}
      {% if song.has_pro_version %}<span class="song-card-tag">Spotify</span>{% endif %}
      {% if song.has_home_version and not song.has_pro_version %}<span class="song-card-tag">Bandcamp</span>{% endif %}
    </div>
  </div>
</a>

---
layout: base.njk
title: Store
permalink: /store/
---

<h1>Store</h1>
<p class="eyebrow">Galactic Panic merch — incoming transmission</p>

<p>
  Merch is incoming. Grab it while supplies last — only 30 of each tee and CD
  exist in this sector of the galaxy. Checkout is handled securely by Square.
</p>

<div class="store-grid">
  {% for p in products %}
  <div class="product-card">
    <div class="product-art">
      {% image p.image, p.alt, "(max-width: 600px) 45vw, 320px" %}
    </div>
    <div class="product-body">
      <div class="product-name">{{ p.name }}</div>
      {% if p.sold_out %}
        <div class="product-soldout">Sold Out</div>
      {% elif p.checkout_url %}
        <span class="product-price">{{ p.price }}</span>
        <a class="product-buy-now"
           href="{{ p.checkout_url }}"
           target="_blank"
           rel="noopener"
           data-goatcounter-click="buy-{{ p.id }}">Buy Now</a>
      {% else %}
        <div class="product-soon">For Sale Soon</div>
      {% endif %}
    </div>
  </div>
  {% endfor %}
</div>
